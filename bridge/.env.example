# ─── WorkOS AuthKit ────────────────────────────────────────────────────────────
# Get these from https://dashboard.workos.com → Authentication → AuthKit
# Configure Google and GitHub OAuth providers in the WorkOS dashboard.
# Register your redirect URI there as well.
WORKOS_API_KEY=sk_your_api_key_here
WORKOS_CLIENT_ID=client_your_client_id_here

# Must match exactly what you registered in the WorkOS dashboard
# Example: https://192.168.1.50:5001/auth/callback
WORKOS_REDIRECT_URI=https://your-host-or-ip:5001/auth/callback

# ─── Allowed Emails (comma-separated, no spaces) ───────────────────────────────
# Grammar:  group1,group2,...  where each group is one alias or
# `{a@x;b@y}` for multiple aliases mapping to the SAME human (= same
# `bridge/users/<canonical>/` folder; first alias in a group is canonical).
ALLOWED_EMAILS=you@example.com,other@example.com

# ─── Admin Emails (same grammar as ALLOWED_EMAILS) ─────────────────────────────
# Admins see every user's `bridge/users/<email>/` folder in the file picker
# and via /v1/files/. Non-admins only see their own canonical folder under
# `bridge/users/` (other users' folders are filtered out at list time and
# return 403 on direct access). Empty/unset = no admins.
# Examples:
#   ADMIN_EMAILS=root@example.com
#   ADMIN_EMAILS={root@example.com;root.alt@example.com},second-admin@example.com
ADMIN_EMAILS=

# ─── Session ───────────────────────────────────────────────────────────────────
# Random string used to sign session cookies — change this!
SESSION_SECRET=replace-with-a-long-random-string

# ─── Go-core CLI bearer (Phase 2d) ────────────────────────────────────────────
# Token the yha CLI sends as `Authorization: Bearer <token>`. The Go
# core checks it constant-time and, on match, signs an X-Yha-Trust
# header for proxied requests + responds to /v1/me with a synthetic
# "yha-cli" identity. Lets scripts hit /v1/sessions etc. without a
# browser session.
#
# Generate with: openssl rand -hex 32
# Leave unset to disable bearer auth entirely.
# YHA_BEARER_TOKEN=
# YHA_BEARER_EMAIL=yha-cli@local   # optional override for the synth identity

# ─── Go-core MCP ownership (Phase 2c+) ────────────────────────────────────────
# Set to 1 to have the Go core own the MCP process pool (reads
# mcp-registry.json, autostarts servers in mcp-state.json on boot,
# /v1/mcp/* served Go-native). Default 0 = Node bridge keeps owning
# MCP and Go just proxies /v1/mcp/* through.
# YHA_MCP_AUTOSTART=0

# ─── Shared bridge key (Phase 1.5) ────────────────────────────────────────────
# Shared between Node bridge and Go core for /proxy/tool x-bridge-key auth.
# Auto-generated by yha.sh on first boot; do not commit a real value.
YHA_BRIDGE_KEY=

# ─── Internal app naming rebrand (pre-launch experiments) ─────────────────────
# Override the product name + slogan everywhere. When set, the bridge serves
# `/brand.js` with these values; the frontend reads them at boot and replaces
# the compiled-in defaults ("YHA" / "Your Home Agent · Home is where your
# agent lives.") in document.title and any element tagged data-brand-name /
# data-brand-slogan. Leave both unset for normal YHA branding. Hidden from
# the prefs UI — intended as a private switch for marketing/naming work.
# INTERNAL_APP_NAMING=yha
# INTERNAL_APP_SLOGAN=Your Home Agent
