{
  "id": "by-cpu",
  "label": "Top by CPU",
  "template": "table",
  "data": "data.ts",
  "refresh": "manual",
  "size": { "w": 480, "h": 360 },
  "headline": { "from": "top", "label": "top cpu" },
  "props": {
    "dataPath": "rows",
    "columns": [
      { "header": "CPU%", "valuePath": "cpu", "align": "right" },
      { "header": "MEM%", "valuePath": "mem", "align": "right" },
      { "header": "Command", "valuePath": "command" }
    ]
  },
  "command": { "keywords": ["top", "cpu", "ram", "processes", "ps"] }
}
